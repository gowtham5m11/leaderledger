rules_version = '2';

// LeaderLedger Firestore Security Rules
// -------------------------------------
// Deny-all default. Each collection allows the narrowest possible access.
// The client cannot bypass these — they are enforced by Firestore at Google.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --- Reaction helpers ---------------------------------------------------
    function reactionKeys() {
      return ['useful', 'concerned', 'needs_investigation'];
    }

    // A reactions doc holds exactly the 3 counters, all non-negative ints.
    function validReactionDoc(d) {
      return d.keys().hasOnly(reactionKeys())
        && d.useful is int && d.useful >= 0
        && d.concerned is int && d.concerned >= 0
        && d.needs_investigation is int && d.needs_investigation >= 0;
    }

    // A single counter may move by at most 1 per write (toggle / switch).
    function movesByAtMostOne(next, prev) {
      return next >= prev - 1 && next <= prev + 1;
    }

    // --- User profile -------------------------------------------------------
    // Each authenticated user maintains exactly one /users/{uid} doc that
    // mirrors their Auth profile. They (and admins) can read it; only they
    // can write it; the owner (or an admin) can delete it for DPDP/GDPR
    // right-to-erasure. AccountPage clears bookmarks + the throttle doc
    // before deleting the parent. Reports are kept for moderation —
    // privacy policy documents this.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['displayName', 'email', 'photoURL', 'createdAt', 'lastLogin']
           )
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string;

      // `policyVersion` is written by PolicyGate.jsx when the user accepts
      // the current Privacy Policy + Terms. Owner-writable, validated as int.
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'photoURL', 'lastLogin', 'policyVersion'])
        && request.resource.data.email == resource.data.email
        && (
             !request.resource.data.diff(resource.data).affectedKeys().hasAny(['policyVersion'])
             || (request.resource.data.policyVersion is int
                 && request.resource.data.policyVersion >= 1)
           );

      allow delete: if isOwner(uid) || isAdmin();

      // --- Bookmarks ------------------------------------------------------
      // Subcollection: /users/{uid}/bookmarks/{candidateId}
      // Doc body is just { createdAt }.
      match /bookmarks/{candidateId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid)
          && candidateId.size() <= 64
          && candidateId.matches('[A-Za-z0-9_-]+')
          && request.resource.data.keys().hasOnly(['createdAt']);
        allow delete: if isOwner(uid);
      }

      // --- Per-uid metadata (currently just the report throttle) ---------
      // /users/{uid}/meta/throttle  { lastReportAt: <server timestamp> }
      // The /reports/{} create rule reads this doc to enforce a 10s cooldown.
      match /meta/{key} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid)
          && key == 'throttle'
          && request.resource.data.keys().hasOnly(['lastReportAt'])
          && request.resource.data.lastReportAt == request.time;
      }
    }

    // --- Reports ------------------------------------------------------------
    // Any signed-in user can create a report for a candidate. The author can
    // read their own. Only admins can list, update status, or delete.
    // Length caps and `field` enum mirror the client UI (ReportModal.jsx) so
    // a direct SDK call can't smuggle in oversized or off-enum values.
    // Throttle: each create must come at least 10s after the last one, tracked
    // via /users/{uid}/meta/throttle. First report ever has no throttle doc,
    // so the `!exists(...)` branch lets it through.
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
             'uid', 'candidateId', 'candidateName',
             'field', 'currentValue', 'suggestion', 'reason',
             'status', 'createdAt'
           ])
        && request.resource.data.status == 'open'
        && request.resource.data.field in [
             'education', 'profession', 'criminal_cases',
             'social_media', 'ministries', 'age', 'other'
           ]
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 1
        && request.resource.data.reason.size() <= 1000
        && request.resource.data.suggestion is string
        && request.resource.data.suggestion.size() <= 500
        && request.resource.data.currentValue is string
        && request.resource.data.currentValue.size() <= 500
        && request.resource.data.candidateName is string
        && request.resource.data.candidateName.size() <= 200
        && request.resource.data.candidateId is string
        && request.resource.data.candidateId.size() <= 64
        && (
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)/meta/throttle)
             || request.time >
                  get(/databases/$(database)/documents/users/$(request.auth.uid)/meta/throttle)
                    .data.lastReportAt + duration.value(10, 's')
           );

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow update: if isAdmin()
        || (isSignedIn() 
            && resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status == 'withdrawn');

      allow delete: if isAdmin() 
        || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // --- Reaction counts ----------------------------------------------------
    // /reactions/{candidateId} — public aggregate tally: { useful, concerned,
    // needs_investigation }. Anyone (signed out included) can READ the numbers.
    //
    // The draft spec used `allow write: if request.auth != null`, which would
    // let any signed-in user overwrite the public counts with any value via a
    // direct SDK call. Instead the write rules below pin the doc shape and
    // require every counter to move by at most ±1 per write — so a client can
    // only register a single toggle/switch, never set an arbitrary total. The
    // client commits this together with the user_reactions doc in one batch
    // (see ReactionsContext.jsx) using FieldValue.increment().
    //
    // This is increment-validation, not abuse-proofing: a determined client
    // could still loop ±1 writes. A strict per-user rate limit would need a
    // /users/{uid}/meta throttle doc (as `reports` does) or a Cloud Function.
    // App Check (already wired in firebase.js) is the intended next gate.
    match /reactions/{candidateId} {
      allow read: if true;

      allow create: if isSignedIn()
        && candidateId.size() <= 64
        && candidateId.matches('[A-Za-z0-9_-]+')
        && validReactionDoc(request.resource.data)
        && request.resource.data.useful <= 1
        && request.resource.data.concerned <= 1
        && request.resource.data.needs_investigation <= 1;

      allow update: if isSignedIn()
        && validReactionDoc(request.resource.data)
        && movesByAtMostOne(request.resource.data.useful, resource.data.useful)
        && movesByAtMostOne(request.resource.data.concerned, resource.data.concerned)
        && movesByAtMostOne(request.resource.data.needs_investigation, resource.data.needs_investigation);

      // Aggregate tallies are never deleted by the client.
      allow delete: if false;
    }

    // --- News article reaction counts --------------------------------------
    // /news_reactions/{articleId} — same public-read, increment-locked tally
    // as /reactions, but for news items. articleId is a hash of the article
    // URL (see src/reactions/newsReactionId.js). Kept in its own collection
    // because the news catalogue churns hourly and must NOT be pulled with a
    // single collection-wide listener — counts are loaded per screen.
    match /news_reactions/{articleId} {
      allow read: if true;

      allow create: if isSignedIn()
        && articleId.size() <= 64
        && articleId.matches('[A-Za-z0-9_-]+')
        && validReactionDoc(request.resource.data)
        && request.resource.data.useful <= 1
        && request.resource.data.concerned <= 1
        && request.resource.data.needs_investigation <= 1;

      allow update: if isSignedIn()
        && validReactionDoc(request.resource.data)
        && movesByAtMostOne(request.resource.data.useful, resource.data.useful)
        && movesByAtMostOne(request.resource.data.concerned, resource.data.concerned)
        && movesByAtMostOne(request.resource.data.needs_investigation, resource.data.needs_investigation);

      allow delete: if false;
    }

    // --- Per-user reaction record ------------------------------------------
    // /user_reactions/{uid}/{kind}/{itemId} — one doc per item the user has
    // reacted to: { reaction, timestamp }. `kind` is 'candidates' or 'news'.
    // Owner-only read/write; schema-locked so a direct SDK call can't smuggle
    // in extra fields, an off-enum reaction, or a back-dated timestamp.
    // Toggling a reaction off deletes the doc.
    match /user_reactions/{uid}/{kind}/{itemId} {
      allow read: if isOwner(uid);

      allow create, update: if isOwner(uid)
        && kind in ['candidates', 'news']
        && itemId.size() <= 64
        && itemId.matches('[A-Za-z0-9_-]+')
        && request.resource.data.keys().hasOnly(['reaction', 'timestamp'])
        && request.resource.data.reaction in reactionKeys()
        && request.resource.data.timestamp == request.time;

      allow delete: if isOwner(uid);
    }

    // --- Deny everything else ----------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
