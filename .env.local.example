# Firebase Web App config — copy this file to `.env.local` and fill in.
# Get these values from: Firebase Console → Project Settings → "Your apps" → Web app config.
# Note: these values are PUBLIC by design — security comes from Authorized Domains,
# Firestore Security Rules, and App Check, not from hiding the keys.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN="leaderledger.in"
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: enable App Check (reCAPTCHA v3 site key from Firebase → App Check)
VITE_FIREBASE_APPCHECK_KEY=

# Optional override for where the frontend fetches news.json from. Plan A
# (current) commits news.json to the repo at public/data/news.json, which
# Firebase Hosting serves at /data/news.json. The default fetch path is
# already correct — leave this blank unless you're hosting news.json
# somewhere else (CDN, separate Cloud Storage bucket on Blaze, etc.).
# Example:
#   VITE_NEWS_JSON_URL="https://cdn.example.com/leaderledger/news.json"
VITE_NEWS_JSON_URL=
