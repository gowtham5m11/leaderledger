# Firebase Web App config for production builds.
#
# These values are committed INTENTIONALLY. They are NOT secret credentials.
# Per CLAUDE.md "Auth & Firestore (Google sign-in + bookmarks + reports) →
# Setup (one-time)":
#
#   "Note: these values are PUBLIC by design — security comes from Authorized
#    Domains, Firestore Security Rules, and App Check, not from hiding the
#    keys."
#
# Anyone with DevTools can already read these values from the deployed JS
# bundle (Vite bakes them in at build time as `import.meta.env.VITE_*`).
# Committing them to the repo just makes the GitHub Actions production
# build self-sufficient — no GH secrets to provision, no service account to
# manage just for env-var injection.
#
# Vite env-file load order (https://vite.dev/guide/env-and-mode#env-files):
#   .env < .env.[mode] < .env.local < .env.[mode].local
# Local dev/build reads .env.local (gitignored, your personal copy) which
# OVERRIDES this file. CI builds — where .env.local doesn't exist — read
# this file instead. So updating values here does not affect your local
# behavior; only CI / fresh-clone builds.
#
# Security layers that actually matter (not these env values):
#   - Firebase Console → Authentication → Settings → Authorized domains
#   - firestore.rules (committed in this repo)
#   - App Check (reCAPTCHA v3, configured via VITE_FIREBASE_APPCHECK_KEY)
#
# Future-you reading this: do not panic about "committed secrets". The
# Firebase API key is a public identifier, not an authentication token.

VITE_FIREBASE_API_KEY=AIzaSyCaSBQyBTrQrEkWzIbDOu-1gBD0sXuDfas
VITE_FIREBASE_AUTH_DOMAIN=leaderledger.in
VITE_FIREBASE_PROJECT_ID=leaderledger-da9a6
VITE_FIREBASE_STORAGE_BUCKET=leaderledger-da9a6.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=493711665773
VITE_FIREBASE_APP_ID=1:493711665773:web:65cc078885710c7bb6ed64
